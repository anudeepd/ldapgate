# ldapgate configuration example
# Copy to ldapgate.yaml and customize for your environment

ldap:
  # LDAP server URL (ldap:// for plain, ldaps:// for TLS)
  url: ldaps://dc.example.com:636

  # Service account DN for directory searches
  bind_dn: CN=svc,CN=Users,DC=example,DC=com
  bind_password: your-service-account-password

  # Base DN for user searches
  base_dn: DC=example,DC=com

  # User filter - choose one:
  # Active Directory:
  user_filter: "(sAMAccountName={username})"
  # OpenLDAP:
  # user_filter: "(uid={username})"

  # Optional: restrict access to group members
  # group_dn: CN=app-users,CN=Users,DC=example,DC=com

  # LDAP connection timeout in seconds
  timeout: 10

  # TLS / Mutual TLS (optional)
  # For ldaps:// with a corporate CA (e.g. DBS/NiFi setup):
  #   Convert JKS to PEM first:
  #     keytool -importkeystore -srckeystore keystore.jks -destkeystore client.p12 -deststoretype PKCS12
  #     openssl pkcs12 -in client.p12 -nokeys -out client.crt.pem
  #     openssl pkcs12 -in client.p12 -nocerts -nodes -out client.key.pem
  #     keytool -importkeystore -srckeystore truststore.jks -destkeystore trust.p12 -deststoretype PKCS12
  #     openssl pkcs12 -in trust.p12 -nokeys -out ca.crt.pem
  # tls_ca_cert_file: ./conf/ca.crt.pem
  # tls_client_cert_file: ./conf/client.crt.pem
  # tls_client_key_file: ./conf/client.key.pem
  # tls_validate: REQUIRED          # NONE | OPTIONAL | REQUIRED (default: REQUIRED)
  # use_starttls: false             # true for ldap:// + STARTTLS; false for ldaps:// (default)
  # follow_referrals: true          # follow LDAP referrals (default: true)

proxy:
  # Listen address and port
  listen_host: 0.0.0.0
  listen_port: 9000

  # Backend service URL to proxy traffic to
  backend_url: http://localhost:8080

  # Secret key for signing session cookies (CHANGE THIS!)
  # Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
  secret_key: change-me-to-something-random-and-secure

  # Session time-to-live in seconds (default: 3600 = 1 hour)
  session_ttl: 3600

  # Header name for authenticated username (for backend apps)
  user_header: X-Forwarded-User

  # Login page path
  login_path: /_auth/login

  # Application name shown in login form
  app_name: "My Application"

# --- AD Global Catalog with mutual TLS example ---
# ldap:
#   url: ldaps://dc.example.com:3269
#   bind_dn: svc@example.com      # UPN format, or full DN
#   bind_password: "<Manager Password>"
#   base_dn: DC=example,DC=com
#   user_filter: "(sAMAccountName={username})"
#   timeout: 10
#   tls_ca_cert_file: ./conf/ca.crt.pem
#   tls_client_cert_file: ./conf/client.crt.pem
#   tls_client_key_file: ./conf/client.key.pem
# proxy:
#   session_ttl: 43200    # 12 hours
